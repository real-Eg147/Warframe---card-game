<Window x:Class="WpfApp1.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Warframe Combat Simulator" Height="880" Width="695" Background="#1e1e1e">

    <StackPanel Margin="20,20,20,-6">

        <TextBlock x:Name="EnemyNameTxt" Text="Nemico..." FontSize="20" Foreground="White" HorizontalAlignment="Center" Margin="0,0,0,10"/>

        <Label Content="Scudi" Foreground="Cyan"/>
        <ProgressBar x:Name="ShieldBar" Height="20" Foreground="Cyan" Background="#333" Maximum="100"/>

        <Grid Height="20" Margin="5">
            <ProgressBar x:Name="ArmorBar" 
                 Foreground="Yellow" 
                 Background="#333" 
                 Maximum="1" 
                 Value="0.0" />

            <TextBlock x:Name="ArmorText" 
               Text="0%" 
               HorizontalAlignment="Center" 
               VerticalAlignment="Center" 
               Foreground="White" 
               FontWeight="Bold" />
        </Grid>

        <Label Content="Salute" Foreground="Red" Margin="0,10,0,0"/>
        <ProgressBar x:Name="HealthBar" Height="20" Foreground="Red" Background="#333" Maximum="100"/>

        <TextBlock x:Name="LogTxt" Height="295" Margin="0,20,0,0" Foreground="#FF50CA00" TextWrapping="Wrap" Background="Black" Padding="5"/>

        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="Genera Grineer" Click="SpawnGrineer_Click" Margin="5" Padding="10"/>
        </UniformGrid>
        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="Genera Corpus" Click="SpawnCorpus_Click" Margin="5" Padding="10"/>
        </UniformGrid>
        <UniformGrid Columns="2" Margin="0,20,0,0">
            <Button Content="Genera Infested" Click="SpawnInfested_Click" Margin="5" Padding="10"/>
        </UniformGrid>
        <Label Content="Seleziona la tua arma:" Foreground="White" Margin="0,10,0,0"/>
        <ComboBox x:Name="WeaponCombo" SelectedIndex="0" SelectionChanged="WeaponCombo_SelectionChanged" RenderTransformOrigin="0.534,5.183" Height="39" Width="184">
            <ComboBoxItem Content="Fucile d'assalto"/>
            <ComboBoxItem Content="Pistola"/>
            <ComboBoxItem Content="Fucile a pompa"/>
            <ComboBoxItem Content="Fucile di precisione"/>
        </ComboBox>
        <Button Content="Attacca!" Click="Attack_Click" Padding="10" Background="DarkRed" Foreground="White"/>
    </StackPanel>
</Window>